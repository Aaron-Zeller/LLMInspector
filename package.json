{
  "name": "colorcode-ai-literacy",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "COLORCODE AI Literacy Assessment Tool — ETH Zurich",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "nodemon server.js",
    "dev:web": "vite --host 0.0.0.0 --port 3002",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3002",
    "start": "node server.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.4"
  }
}
