# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it contains your database password.

# Render PostgreSQL — use the "Internal Database URL" from your Render dashboard
# (Internal URL is faster and free within Render's network; use External URL for local dev)
DATABASE_URL=postgres://user:password@hostname:5432/dbname

# Port the Express server listens on (Render sets this automatically)
PORT=3001
