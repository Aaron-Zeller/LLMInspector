# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it contains your database password.

# Render PostgreSQL — use the Internal Database URL in Render and the External URL for local development
DATABASE_URL=postgres://user:password@hostname:5432/dbname

# Port the Express server listens on (Render sets this automatically)
PORT=3001

# Frontend overlay flags.
# In local development you usually want this true.
# In Render production builds this should be false.
VITE_SHOW_SEGMENT_IDS=true
